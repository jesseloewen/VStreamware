# Flask runtime settings
FLASK_RUN_HOST=0.0.0.0
FLASK_RUN_PORT=8523
FLASK_DEBUG=1
FLASK_USE_RELOADER=0

# App secret for session/flash security
SECRET_KEY=change-me-in-production

# Stream recording defaults
STREAMLINK_COMMAND=streamlink
STREAM_DEFAULT_QUALITY=best
RECORDINGS_DIR=recordings
STREAM_SETTINGS_FILE=recording_settings.json
AUTO_RECORD_POLL_SECONDS=30
LIVE_EDGE_OFFSET_SECONDS=60

# Twitch chat capture (stored as UTC NDJSON sidecar per recording)
TWITCH_CHAT_CAPTURE_ENABLED=1
TWITCH_CHAT_HOST=irc.chat.twitch.tv
TWITCH_CHAT_PORT=6667
# Optional bot auth; if unset, anonymous read-only mode is used.
TWITCH_CHAT_BOT_USERNAME=
TWITCH_CHAT_BOT_OAUTH_TOKEN=
TWITCH_CHAT_ANON_PREFIX=justinfan
TWITCH_CHAT_CONNECT_TIMEOUT_SECONDS=12
TWITCH_CHAT_RECEIVE_TIMEOUT_SECONDS=30
TWITCH_CHAT_RECONNECT_INITIAL_SECONDS=2
TWITCH_CHAT_RECONNECT_MAX_SECONDS=45



# Pushover notifications
# Required for notifications to send
PUSHOVER_APP_TOKEN=your-pushover-app-token
PUSHOVER_USER_KEY=your-pushover-user-key

# Optional overrides
PUSHOVER_API_URL=https://api.pushover.net/1/messages.json
PUSHOVER_TIMEOUT_SECONDS=5
